[sub_resource type="GDScript" id="GDScript_mel2l"]
script/source = "extends AnimatableBody3D

@export var target_offset := Vector3(3, 0, 0)
@export var duration := 3.0

var start_position: Vector3

func _ready() -> void:
	start_position = global_position
	var target_position = start_position + target_offset

	var tween = create_tween().set_loops()
	
	tween.tween_property(self, \"global_position\", target_position, duration)\\
		.set_trans(Tween.TRANS_SINE)\\
		.set_ease(Tween.EASE_IN_OUT)
		
	tween.tween_property(self, \"global_position\", start_position, duration)\\
		.set_trans(Tween.TRANS_SINE)\\
		.set_ease(Tween.EASE_IN_OUT)
"

